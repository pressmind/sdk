# SDK Test Environment — NOT for production use.
# This file is only used by the test infrastructure (Docker, PHPUnit, fixture recording).
# Copy to .env and fill in your values. Never commit .env.
#
# Used by: tests/bin/record-api-snapshot.php, make record-snapshot, docker compose (import-test)
# See: documentation/testing.md

# Pressmind API (required for recording fixtures)
PM_API_KEY=
PM_API_USER=
PM_API_PASSWORD=

# Optional: override for ImportIntegration tests (defaults in phpunit.xml / docker-compose)
# DB_HOST=localhost
# DB_NAME=pressmind_test
# DB_USER=root
# DB_PASS=
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=pressmind_test
