#!/usr/bin/env php
<?php
/**
 * Pressmind SDK FileStorage import (metadata + optional attachment downloads).
 *
 * Usage:
 *   php bin/file-storage-import
 *   php bin/file-storage-import --force --no-download
 */

$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

$autoloaderFound = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require_once $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (!$autoloaderFound) {
    fwrite(STDERR, "Autoloader not found. Please run 'composer install'.\n");
    exit(1);
}

$command = new \Pressmind\CLI\FileStorageImportCommand();
exit($command->run($argv));
