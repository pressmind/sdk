{
    "name": "pressmind/sdk",
    "description": "PHP SDK for pressmind PIM – imports, caches and indexes touristic and editorial content (MySQL, MongoDB, OpenSearch) with a full search and template API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Pressmind Applications GmbH",
            "email": "support@pressmind.de"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.0",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-bcmath": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-readline": "*",
        "ext-mbstring": "*",
        "ext-gd": "*",
        "ext-zlib": "*",
        "ext-fileinfo": "*",
        "ext-redis": "*",
        "ext-imagick": "*",
        "gettext/gettext": "^5.7",
        "jc21/clitable": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "opensearch-project/opensearch-php": "^2.4",
        "symfony/http-client": "^7.0",
        "nyholm/psr7": "^1.8",
        "aws/aws-sdk-php": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Pressmind\\": "src/Pressmind/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pressmind\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/integrity-check"
    ],
    "scripts": {
        "integrity-check": "php bin/integrity-check",
        "post-install-cmd": [
            "@php bin/integrity-check --non-interactive"
        ],
        "post-update-cmd": [
            "@php bin/integrity-check --non-interactive"
        ],
        "test": "vendor/bin/phpunit --testsuite Unit --no-coverage",
        "test:integration": "vendor/bin/phpunit --testsuite Integration --no-coverage",
        "test:import": "vendor/bin/phpunit --testsuite ImportIntegration --no-coverage",
        "test:all": "vendor/bin/phpunit --no-coverage",
        "test:coverage": "vendor/bin/phpunit --testsuite Unit --coverage-html build/coverage --coverage-text build/coverage.txt"
    },
    "suggest": {
        "opensearch-project/opensearch-php": "Required for OpenSearch indexing and search (^2.4)",
        "symfony/http-client": "Required for OpenSearch connectivity via PSR-18 (^7.0)",
        "nyholm/psr7": "PSR-7/PSR-17 HTTP message implementation, required for OpenSearch (^1.8)",
        "aws/aws-sdk-php": "Required for S3 storage provider (^3.0)"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
